{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs", 
    "moduleResolution": "node",
    "rootDir": "./",                    
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,                    
    "skipLibCheck": true,
    "verbatimModuleSyntax": false      
  },
  "include": ["src/**/*", "prisma/**/*"] 
}