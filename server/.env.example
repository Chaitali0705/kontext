# Environment Variables Template
# Copy this to .env and fill in your values

# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="your_postgresql_connection_string_here"

# ===========================
# LLM / AI Configuration
# ===========================

# Choose your LLM provider: 'openai' | 'anthropic' | 'local' | 'mock'
# Use 'mock' for simple extraction-based summaries (no API needed)
LLM_PROVIDER=mock

# OpenAI Configuration (if using OpenAI)
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-your-key-here
# OPENAI_MODEL=gpt-4-turbo

# Anthropic Configuration (if using Claude)
# Get your key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Local LLM Configuration (if using Ollama/local)
# LOCAL_LLM_ENDPOINT=http://localhost:11434
# LOCAL_LLM_MODEL=llama2

# ===========================
# Future Features
# ===========================

# Email Service (for team invitations)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Redis (for caching/sessions)
# REDIS_URL=redis://localhost:6379

# JWT Secret (for authentication)
# JWT_SECRET=your-super-secret-key-change-this-in-production
